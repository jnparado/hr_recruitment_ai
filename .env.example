# NEVER put real keys in this file — they will be committed to git.
# Copy this file to .env.local and fill in your real values there.

# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: chat model (defaults to gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: voice for spoken interview questions (defaults to nova)
# OPENAI_TTS_VOICE=nova

# Optional: TTS / STT models
# OPENAI_TTS_MODEL=tts-1
# OPENAI_STT_MODEL=whisper-1

# Supabase — storage buckets (both public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RESUME_BUCKET=upload_resume
SUPABASE_CERTIFICATE_BUCKET=certificate

# Database password (Project Settings → Database) — used by npm run db:setup
# SUPABASE_DB_PASSWORD=your-database-password

# n8n automation (optional)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/application-received
N8N_WEBHOOK_SECRET=your-shared-webhook-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
RECRUITER_EMAIL=recruiter@company.com
