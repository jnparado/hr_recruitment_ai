# NEVER put real keys in this file — they will be committed to git.
# Copy this file to .env.local and fill in your real values there.

# Get your API key at https://console.x.ai
XAI_API_KEY=your-xai-api-key-here

# Optional: override the Grok model (defaults to grok-4.3)
# GROK_MODEL=grok-4.3

# Optional: voice for the spoken interview questions (defaults to eve)
# GROK_TTS_VOICE=eve

# Supabase — resume storage (bucket: Candidate_Record_Created)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RESUME_BUCKET=Candidate_Record_Created
