# NEVER put real keys in this file — they will be committed to git.
# Copy this file to .env.local and fill in your real values there.

# OpenAI — preferred when set (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Cursor AI — used only if OPENAI_API_KEY is not set
# https://cursor.com/dashboard/integrations
CURSOR_API_KEY=your-cursor-api-key
# CURSOR_MODEL=composer-2.5

# Supabase — Project Settings → API (storage / DB; not used for recruiter login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RESUME_BUCKET=upload_resume

# Database password (Project Settings → Database) — used by npm run db:setup
# SUPABASE_DB_PASSWORD=your-database-password

# n8n automation (optional)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/application-received
N8N_WEBHOOK_SECRET=your-shared-webhook-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Static recruiter login (defaults to recruiter@gmail.com / 12345 if unset)
RECRUITER_LOGIN_EMAIL=recruiter@gmail.com
RECRUITER_LOGIN_PASSWORD=12345
# Optional: n8n notification recipient (can match login email)
RECRUITER_EMAIL=recruiter@gmail.com
